{
  "name": "policyevgos",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.js",
  "type": "module",
  "description": "Policy Evaluation Analysis System - Local LLM-powered Generative UI",
  "scripts": {
    "dev": "vite",
    "backend:dev": "node ./scripts/run-backend-dev.mjs",
    "backend:package": "node ./scripts/prepare-backend-package.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e:real": "playwright test",
    "debug:backend:json": "node ./scripts/debug-yomitoku-json.mjs",
    "debug:ocr:json": "node ./scripts/debug-yomitoku-json.mjs",
    "debug:yomitoku:json": "node ./scripts/debug-yomitoku-json.mjs",
    "electron:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "electron:dev:external-backend": "concurrently -k \"vite\" \"wait-on tcp:5173 && node ./scripts/run-electron-external-backend.mjs\"",
    "debug:full": "node ./scripts/run-debug-full.mjs",
    "electron:build": "npm run build && npm run backend:package && electron-builder"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.23.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.29.1",
    "vite": "^6.2.3",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.policyeval.gos",
    "productName": "PolicyEval GOS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
